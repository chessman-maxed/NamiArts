rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /artworks/{artworkId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == 'nameearts@gmail.com';
    }
    match /stories/{storyId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == 'nameearts@gmail.com';
    }
  }
}
